# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored and never committed.

# --- RPC endpoints ---
# Required for fork tests (contracts matching *Fork* or *Polygon*).
POLYGON_RPC_URL=
BASE_RPC_URL=
# Optional: used by PositionRegistry.t.sol's Sepolia-fork setup and by
# scripts broadcasting to Sepolia.
SEPOLIA_RPC_URL=

# --- Deployer identity (scripts) ---
# Scripts resolve their broadcast signer from env in a consistent order:
#   1. ETH_FROM        -- hardware wallet / keystore flow
#   2. PRIVATE_KEY     -- raw key, fallback for headless deploys
#   3. (CreateCouncilNftsAndStreams only) falls back to an on-chain MEXC
#      address that reliably holds enough TEL for the stream deposits.
ETH_FROM=
PRIVATE_KEY=

# V4HookMinerDeployer uses its own env var (raw uint private key):
DEPLOYER_PK=

# --- V4HookMinerDeployer: chain infrastructure addresses ---
# Uniswap v4 production addresses + Telcoin deployment targets. Only needed
# when running script/V4HookMinerDeployer.s.sol. `setUp()` reads every one
# of these at startup, so they must all be set (use 0x111..1 placeholders
# for the chain you're not deploying to).

# Polygon (chainid 137)
POLYGON_POOL_MANAGER=
POLYGON_POSITION_MANAGER=
POLYGON_UNIVERSAL_ROUTER=
POLYGON_STATE_VIEW=
POLYGON_TEL_TOKEN=
POLYGON_WETH_TOKEN=
POLYGON_USDC_TOKEN=
POLYGON_EMXN_TOKEN=
POLYGON_SUPPORT_SAFE=

# Base (chainid 8453)
BASE_POOL_MANAGER=
BASE_POSITION_MANAGER=
BASE_UNIVERSAL_ROUTER=
BASE_STATE_VIEW=
BASE_TEL_TOKEN=
BASE_WETH_TOKEN=
BASE_USDC_TOKEN=
BASE_EMXN_TOKEN=
BASE_SUPPORT_SAFE=
