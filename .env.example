# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored and never committed.

# --- RPC endpoints ---
# Required for fork tests (contracts matching *Fork* or *Polygon*).
POLYGON_RPC_URL=
BASE_RPC_URL=
# Optional: used by PositionRegistry.t.sol's Sepolia-fork setup and by
# scripts broadcasting to Sepolia.
SEPOLIA_RPC_URL=

# --- Deployer identity (scripts) ---
# Scripts resolve their broadcast signer from env in a consistent order:
#   1. ETH_FROM        -- hardware wallet / keystore flow
#   2. PRIVATE_KEY     -- raw key, fallback for headless deploys
#   3. (CreateCouncilNftsAndStreams only) falls back to an on-chain MEXC
#      address that reliably holds enough TEL for the stream deposits.
ETH_FROM=
PRIVATE_KEY=

# V4HookMinerDeployer uses its own env var (raw uint private key):
DEPLOYER_PK=

# --- Chain infrastructure addresses ---
# Defaults live in `script/shared/PolygonAddresses.sol` and `script/shared/BaseAddresses.sol`.
# The script reads each via `vm.envOr(KEY, library_default)`, so you only need to set the env
# vars below if you want to OVERRIDE the library defaults (e.g., for a testnet fork or staging
# environment). For mainnet deployments, leave them unset and the library defaults apply.
#
# Available override keys (all optional):
#   POLYGON_POOL_MANAGER, POLYGON_POSITION_MANAGER, POLYGON_UNIVERSAL_ROUTER, POLYGON_STATE_VIEW,
#   POLYGON_TEL_TOKEN, POLYGON_WETH_TOKEN, POLYGON_USDC_TOKEN, POLYGON_EMXN_TOKEN, POLYGON_SUPPORT_SAFE,
#   BASE_POOL_MANAGER, BASE_POSITION_MANAGER, BASE_UNIVERSAL_ROUTER, BASE_STATE_VIEW,
#   BASE_TEL_TOKEN, BASE_WETH_TOKEN, BASE_USDC_TOKEN, BASE_EMXN_TOKEN, BASE_SUPPORT_SAFE.
